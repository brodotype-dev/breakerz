    "xl": "0 20px 25px rgba(0, 0, 0, 0.3)",
    "elevated": "0 4px 24px rgba(0, 0, 0, 0.4)"
  },
  "transitions": {
    "fast": "150ms cubic-bezier(0.4, 0, 0.2, 1)",
    "base": "200ms cubic-bezier(0.4, 0, 0.2, 1)",
    "slow": "300ms cubic-bezier(0.4, 0, 0.2, 1)"
  },
  "zIndex": {
    "base": 0,
    "dropdown": 1000,
    "sticky": 1100,
    "overlay": 1200,
    "modal": 1300,
    "toast": 1400
  },
  "components": {
    "ElevatedCard": {
      "borderWidth": "2px",
      "borderRadius": "0.75rem",
      "padding": "1.5rem",
      "backgroundColor": "#131820",
      "borderColor": "#2a3142",
      "boxShadow": "0 4px 24px rgba(0, 0, 0, 0.4)"
    },
    "StepHeader": {
      "numberBox": {
        "width": "40px",
        "height": "40px",
        "borderRadius": "0.5rem",
        "background": "linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%)",
        "boxShadow": "0 0 20px rgba(59, 130, 246, 0.3)"
      },
      "title": {
        "fontSize": "1.25rem",
        "fontWeight": 700,
        "color": "#f5f5f7"
      },
      "subtitle": {
        "fontSize": "0.875rem",
        "color": "#a8adb8"
      }
    },
    "FormLabel": {
      "fontSize": "0.75rem",
      "fontWeight": 700,
      "textTransform": "uppercase",
      "letterSpacing": "0.05em",
      "color": "#a8adb8",
      "marginBottom": "0.75rem"
    },
    "SegmentedControl": {
      "container": {
        "borderRadius": "0.5rem",
        "padding": "0.375rem",
        "backgroundColor": "#0a0e1a",
        "borderColor": "#1e2533"
      },
      "activeButton": {
        "backgroundColor": "#3b82f6",
        "color": "#ffffff",
        "boxShadow": "0 0 20px rgba(59, 130, 246, 0.4)"
      },
      "inactiveButton": {
        "backgroundColor": "transparent",
        "color": "#a8adb8"
      }
    },
    "CounterInput": {
      "container": {
        "borderRadius": "0.5rem",
        "padding": "0.625rem 1rem",
        "backgroundColor": "#0a0e1a",
        "borderColor": "#1e2533"
      },
      "value": {
        "fontFamily": "'JetBrains Mono', monospace",
        "fontSize": "1.5rem",
        "fontWeight": 700,
        "color": "#f5f5f7"
      },
      "button": {
        "fontSize": "1.25rem",
        "fontWeight": 700,
        "color": "#3b82f6",
        "hoverScale": 1.25
      }
    },
    "LargeCTAButton": {
      "height": "3.5rem",
      "width": "100%",
      "borderRadius": "0.5rem",
      "fontSize": "1.125rem",
      "fontWeight": 700,
      "variants": {
        "primary": {
          "backgroundColor": "#3b82f6",
          "color": "#ffffff",
          "boxShadow": "0 0 20px rgba(59, 130, 246, 0.4)"
        },
        "success": {
          "backgroundColor": "#22c55e",
          "color": "#ffffff",
          "boxShadow": "0 0 20px rgba(34, 197, 94, 0.4)"
        },
        "danger": {
          "backgroundColor": "#dc2626",
          "color": "#ffffff",
          "boxShadow": "0 0 20px rgba(220, 38, 38, 0.4)"
        },
        "secondary": {
          "backgroundColor": "#131820",
          "color": "#f5f5f7",
          "border": "2px solid #2a3142"
        }
      }
    }
  }
